# ─── Postgres ──────────────────────────────────────────────
POSTGRES_USER=devpulse
POSTGRES_PASSWORD=devpulse123
POSTGRES_DB=devpulse

# ─── Auth Service ──────────────────────────────────────────
AUTH_PORT=3001
JWT_SECRET=change_this_in_production_min_32_chars
AUTH_DB_URL=postgresql://devpulse:devpulse123@postgres:5432/devpulse

# ─── URL Service ───────────────────────────────────────────
URL_PORT=3002
MONGO_URI=mongodb://mongo:27017/urldb
REDIS_URL=redis://redis:6379
AUTH_SERVICE_URL=http://auth-service:3001
BASE_URL=http://localhost:3002
KAFKA_BROKER=kafka:9092

# ─── Analytics Service ────────────────────────────────────
ANALYTICS_PORT=3003
ANALYTICS_DB_URL=postgresql://devpulse:devpulse123@postgres:5432/devpulse
AUTH_SERVICE_URL=http://auth-service:3001

# ─── Kafka ─────────────────────────────────────────────────
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
